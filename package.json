{
  "name": "no3d-tools-website",
  "version": "1.0.0",
  "description": "NO3D Tools website",
  "type": "module",
  "scripts": {
    "build": "node scripts/update-commit-hash.js",
    "start": "doppler run -- npx vercel dev --listen 3001 --yes",
    "update-commit": "node scripts/update-commit-hash.js",
    "fix-vercel": "node scripts/fix-vercel-settings.js",
    "fix-vercel:doppler": "doppler run -- node scripts/fix-vercel-settings.js",
    "fix-vercel:cli": "./scripts/fix-vercel-settings-cli.sh",
    "r2:upload": "node scripts/r2-upload-library-blends.mjs",
    "publish-blog": "node scripts/publish-blog.mjs",
    "publish-blog:dry": "node scripts/publish-blog.mjs --dry-run",
    "publish-blog:force": "node scripts/publish-blog.mjs --force",
    "send-newsletter": "node scripts/send-newsletter.mjs",
    "send-newsletter:dry": "node scripts/send-newsletter.mjs --dry-run",
    "newsletter:list": "node scripts/send-newsletter.mjs --list"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.758.0",
    "@aws-sdk/s3-request-presigner": "^3.758.0",
    "@supabase/supabase-js": "^2.89.0",
    "@vercel/analytics": "^1.3.1",
    "dotenv": "^17.2.3",
    "gray-matter": "^4.0.3",
    "resend": "^4.0.0",
    "stripe": "^16.12.0"
  },
  "devDependencies": {
    "puppeteer": "^24.33.0"
  }
}
